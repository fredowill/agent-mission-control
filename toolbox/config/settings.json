{
  "permissions": {
    "allow": [
      "Bash:*",
      "Read:*",
      "Write:*",
      "Edit:*",
      "Glob:*",
      "Grep:*",
      "WebFetch:*",
      "WebSearch:*",
      "Agent:*",
      "NotebookEdit:*",
      "Skill:*",
      "TaskCreate:*",
      "TaskUpdate:*",
      "TaskList:*",
      "TaskGet:*",
      "EnterPlanMode:*",
      "ExitPlanMode:*",
      "AskUserQuestion:*",
      "EnterWorktree:*",
      "ListMcpResourcesTool:*",
      "ReadMcpResourceTool:*",
      "mcp__github:*",
      "mcp__azure-devops-custom:*"
    ]
  },
  "model": "opus[1m]",
  "autoUpdatesChannel": "latest",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/emeskel/Claude/projects/agent-mission-control/hook.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/emeskel/Claude/projects/agent-mission-control/hook.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/emeskel/Claude/projects/agent-mission-control/prompt-hook.js"
          }
        ]
      }
    ]
  }
}
